{
  "name": "vs-pos",
  "version": "1.0.0",
  "description": "VS pos - 专业按摩/SPA POS系统",
  "main": "electron/main.js",
  "scripts": {
    "start": "start src/index.html",
    "dev": "npx live-server src --port=3000 --host=localhost",
    "dev:electron": "electron .",
    "lint": "npx eslint src/utils.js src/constants.js src/i18n.js src/demo-data.js",
    "lint:fix": "npx eslint src/utils.js src/constants.js src/i18n.js src/demo-data.js --fix",
    "format": "npx prettier --write \"src/**/*.html\" \"src/**/*.js\"",
    "format:check": "npx prettier --check \"src/**/*.html\" \"src/**/*.js\"",
    "format:fix": "npm run format",
    "test": "npx jest tests/",
    "test:watch": "npx jest tests/ --watch",
    "test:coverage": "npx jest tests/ --coverage",
    "playwright": "npx playwright test",
    "playwright:install": "npx playwright install chromium",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install",
    "open:vscode": "code .",
    "open:folder": "explorer .",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap add ios",
    "cap:android": "npx cap add android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "electron:build": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "massage",
    "spa",
    "beauty",
    "pos-system",
    "retail",
    "service-industry"
  ],
  "author": "VS Pos Team",
  "contributors": [],
  "funding": {},
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@capacitor/cli": "^5.5.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "live-server": "^1.2.2",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "@capacitor/core": "^5.5.0",
    "@capacitor/ios": "^5.5.0",
    "@capacitor/android": "^5.5.0",
    "electron-store": "^8.1.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vspos/vs-pos.git"
  },
  "bugs": {
    "url": "https://github.com/vspos/vs-pos/issues"
  },
  "homepage": "https://github.com/vspos/vs-pos#readme"
}
