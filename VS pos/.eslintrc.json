{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "globals": {
    "CONFIG": "readonly",
    "services": "writable",
    "orders": "writable",
    "tickets": "writable",
    "invoices": "writable",
    "members": "writable",
    "employees": "writable",
    "commissions": "writable",
    "suspendedOrders": "writable",
    "shifts": "writable",
    "features": "writable",
    "settings": "writable",
    "cart": "writable",
    "currentCustomerType": "writable",
    "currentMember": "writable",
    "selectedPayment": "writable",
    "currentCategory": "writable",
    "currentTip": "writable",
    "currentTipPercent": "writable",
    "showModal": "writable",
    "resolve": "writable",
    "streets": "writable",
    "strees": "writable"
  },
  "rules": {
    "indent": ["warn", 4],
    "linebreak-style": ["off"],
    "quotes": ["warn", "single"],
    "semi": ["warn", "always"],
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "warn"
  }
}
