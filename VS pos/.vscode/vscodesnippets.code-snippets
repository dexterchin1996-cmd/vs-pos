  "VS Pos - 控制台日志": {
    "prefix": "vslog",
    "body": [
      "console.log('${1:调试信息}:', ${2:value});"
    ],
    "description": "VS Pos 控制台日志"
  },
  "VS Pos - 空状态": {
    "prefix": "vsempty",
    "body": [
      "<div class=\"empty-state\">",
      "    <div class=\"icon\">${1:📭}</div>",
      "    <p>${2:暂无数据}</p>",
      "    <button class=\"btn btn-primary\" onclick=\"showAdd${3:Name}Modal()\">+ 添加${4:名称}</button>",
      "</div>"
