      "<div class=\"page-header\">",
      "    <h2 class=\"page-title\">${1:页面标题}</h2>",
      "    <div class=\"page-actions\">",
      "        <button class=\"btn btn-primary\" onclick=\"showAdd${2:Name}Modal()\">+ 添加${3:名称}</button>",
      "        <button class=\"btn btn-outline\" onclick=\"export${2:Name}()\">📥 导出</button>",
      "    </div>",
      "</div>"
